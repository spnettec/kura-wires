case "$1" in
    configure)
        STATUS=install
        ;;

    abort-remove)
        echo "Uninstallation failed."
        exit 1
        ;;

    abort-upgrade)
        echo "Upgrade failed."
        exit 1
        ;;

    *)
        echo "postinst called with unknown parameter $1"
        exit 1
        ;;
esac

echo "Installing Kura Wires addon..."
export TIMESTAMP=$(date +%Y%m%d%H%M)
export LOG=/var/log/kura_wires_install_${TIMESTAMP}.log

bash /opt/eclipse/kura/.data/kura_wires_install.sh ${STATUS} /opt/eclipse kura 2>&1 | tee -a $LOG | systemd-cat -t Kura

if test -f /tmp/install_error; then
    echo "Kura Wires addon installation failed."
    rm /tmp/install_error
    exit 1
fi

echo "Kura Wires addon installation completed."
exit 0
