case "$1" in
    remove|purge|disappear)
        STATUS=remove
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade)
        # Don't touch registry on upgrade — preserve install order
        exit 0
        ;;
    *)
        echo "postrm called with unknown parameter $1"
        exit 0
        ;;
esac

echo "Uninstalling Kura Wires addon..."
export TIMESTAMP=$(date +%Y%m%d%H%M)
export LOG=/tmp/kura_wires_install_${TIMESTAMP}.log

{
    echo "Uninstalling Kura Wires addon..."
    echo "  Status: ${STATUS}"
    echo "  Base directory: /opt/eclipse"
    echo "  Kura symlink: kura"

    SIBLING_NAME="wires"
    REGISTRY="/opt/eclipse/kura/framework/sibling-install-order"

    # Remove this sibling from the install-order registry
    if [ -f "${REGISTRY}" ]; then
        echo "  Removing ${SIBLING_NAME} from sibling-install-order"
        TMP=$(mktemp 2>/dev/null || echo "${REGISTRY}.tmp.$$")
        grep -vFx "${SIBLING_NAME}" "${REGISTRY}" > "${TMP}" 2>/dev/null || true
        mv -f "${TMP}" "${REGISTRY}" 2>/dev/null || rm -f "${TMP}"
    else
        echo "  Warning: sibling-install-order registry not found"
    fi

    echo "Kura Wires addon uninstallation completed."
} 2>&1 | tee -a $LOG | systemd-cat -t Kura

mkdir -p /opt/eclipse/kura/log 2>/dev/null
if [ -d /opt/eclipse/kura/log ]; then
    mv $LOG /opt/eclipse/kura/log/ 2>/dev/null
fi

exit 0
