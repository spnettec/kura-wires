case "$1" in
    remove|purge|disappear)
        STATUS=remove
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade)
        # Don't touch registry on upgrade — preserve install order
        exit 0
        ;;
    *)
        echo "postrm called with unknown parameter $1"
        exit 0
        ;;
esac

echo "Uninstalling Kura Wires addon..."
export TIMESTAMP=$(date +%Y%m%d%H%M)
export LOG=/tmp/kura_wires_uninstall_${TIMESTAMP}.log

if [ -f /opt/eclipse/kura/.data/kura_wires_uninstall.sh ]; then
    bash /opt/eclipse/kura/.data/kura_wires_uninstall.sh ${STATUS} /opt/eclipse kura 2>&1 | tee -a $LOG | systemd-cat -t Kura

    mkdir -p /opt/eclipse/kura/log 2>/dev/null
    if [ -d /opt/eclipse/kura/log ]; then
        mv $LOG /opt/eclipse/kura/log/ 2>/dev/null
    fi
fi

exit 0
